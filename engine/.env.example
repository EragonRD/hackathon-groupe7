# ============================================================================
# Engine — configuration IA distante (copier en `engine/.env`, NE PAS committer)
# ============================================================================
# Providers par étape (INDÉPENDANTS — tu peux mixer tes 3 clés) :
#   - Transcription   : groq | local            (OpenRouter/Gemini = pas d'audio)
#   - Résumé/chapitres: groq | openrouter | gemini | local
#   - Traduction      : groq | openrouter | gemini | local
# Ex. mix : ASR=groq, LLM=openrouter, TRANSLATE=gemini.
ENGINE_ASR_PROVIDER=groq
ENGINE_LLM_PROVIDER=groq
ENGINE_TRANSLATE_PROVIDER=groq

# true  : repli local automatique si l'API échoue / pas de clé (modèles locaux requis).
# false : mode 100 % API STRICT -> AUCUN modèle local n'est chargé ni téléchargé.
#         Conséquence : mots-clés et recherche sémantique (MiniLM local) DÉSACTIVÉS,
#         et si un provider distant manque/échoue, l'étape est vide (ou lève pour la
#         transcription). Tout doit passer par les API distantes.
ENGINE_ALLOW_LOCAL_FALLBACK=true

# --- Groq (transcription Whisper + chat LLM) --------------------------------
# Recommandé : garder TRANSCRIPTION et TRADUCTION sur Groq (OpenRouter :free est
# saturé en amont). Modèles chat Groq (limites free tier) :
#   groq/compound                        RPD 250  | TPM 70K | TPD ILLIMITÉ  (idéal traduction volume)
#   llama-3.1-8b-instant                 RPD 14.4K| TPM 6K  | TPD 500K      (rapide, bon défaut)
#   meta-llama/llama-4-scout-17b-16e     RPD 1K   | TPM 30K | TPD 500K      (meilleure qualité multilingue)
#   openai/gpt-oss-20b                   RPD 1K   | TPM 8K  | TPD 200K      (résumé/chapitres)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_LLM_MODEL=openai/gpt-oss-20b
# Modèle de TRADUCTION (séparé du résumé). TESTÉ : scout = 3 langues en ~7s, ar OK.
# Évite llama-3.1-8b-instant (6K TPM -> 429) et groq/compound (agentique, lent).
GROQ_TRANSLATE_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenRouter (chat LLM uniquement) ---------------------------------------
# ATTENTION : les modèles `:free` sont rate-limités en amont (429 fréquents) ->
# peu fiables. Mettre ta propre clé de provider ou préférer Groq.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_TRANSLATE_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Google Gemini / AI Studio (chat LLM uniquement) ------------------------
# Clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_LLM_MODEL=gemini-2.0-flash
# GEMINI_TRANSLATE_MODEL=gemini-2.0-flash

# --- Mistral / La Plateforme (chat LLM uniquement) --------------------------
# Free tier : ~1 req/s max, PAS de parallélisme -> throttle intégré (1.2s/appel).
# Clé : https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_TRANSLATE_MODEL=open-mistral-nemo
# MISTRAL_MIN_INTERVAL=1.2   # secondes entre appels (respect du 1 RPS)

# --- NVIDIA NIM / Riva (TRANSCRIPTION Whisper via gRPC) ---------------------
# Nécessite : pip install nvidia-riva-client
# Clé (nvapi-...) + function-id sur l'onglet « Try API » de :
#   https://build.nvidia.com/openai/whisper-large-v3
# ⚠️ La clé EXPIRE ~30 jours (risque le jour de la démo).
NVIDIA_API_KEY=
NVIDIA_ASR_FUNCTION_ID=
NVIDIA_ASR_SERVER=grpc.nvcf.nvidia.com:443
NVIDIA_ASR_LANGUAGE=multi        # "multi" = auto ; sinon "en-US", "fr-FR", ...

# --- HTTP (timeouts / retries) ----------------------------------------------
ENGINE_HTTP_TIMEOUT=120
ENGINE_HTTP_RETRIES=2
# Plafond du back-off entre tentatives (s) : échoue vite si free tier saturé.
ENGINE_HTTP_MAX_BACKOFF=8

# --- Langues cibles de traduction (réduire pour économiser le quota) ---------
# TARGET_LANGS=fr,en,es

# --- Auth (aligné sur le Core) — laisser tel quel en local ------------------
# ENGINE_REQUIRE_AUTH=false
# JWT_SECRET=dev-secret-change-me

JWT_SECRET=change-me-in-prod
JWT_TTL=15m
# Mono-session : un seul compte connecte a la fois (le dernier login gagne, les
# autres sessions sont expulsees). ACTIF PAR DEFAUT EN PROD (NODE_ENV=production) :
# rien a definir ici. La variable ci-dessous est un OVERRIDE optionnel (toute
# valeur explicite prime sur NODE_ENV) :
#   MONO_SESSION=true   -> force l'activation (ex. tester en dev)
#   MONO_SESSION=false  -> force la desactivation (ATTENTION : desactive aussi en prod)
# Laisser commente pour suivre NODE_ENV.
# MONO_SESSION=true
PORT=3000
# Proxies de confiance pour X-Forwarded-For (anti-usurpation d'IP).
# En prod : mettre UNIQUEMENT le sous-réseau du reverse-proxy.
TRUST_PROXY=loopback, uniquelocal
# Base URL du front (liens d'invitation)
APP_URL=http://localhost:5173
# Engine IA (Pôle 3) : URL du service FastAPI d'analyse vidéo
ENGINE_URL=http://localhost:8000
# Mailjet (envoi d'email d'invitation). Sans ces clés -> simulation (log).
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME=Plateforme Vidéo
# MAILJET_SANDBOX=true   # valide l'appel Mailjet sans délivrer réellement

# Copier en `.env.local` et adapter selon le mode de démo.

# URL du Core (NestJS). En LAN, mettre l'IP de la machine qui héberge le backend,
# ex. http://192.168.1.42:3000 (pas localhost, sinon les autres postes n'y accèdent pas).
VITE_API_URL=http://localhost:3000

# Transport temps réel :
#   broadcast (défaut) -> multi-fenêtres d'UNE machine, 100% offline, sans backend.
#   socket             -> LAN 2-3 machines via la gateway socket.io du Core.
# Pour la démo multi-machines, mettre `socket` ET lancer le backend.
VITE_COLLAB_MODE=broadcast
